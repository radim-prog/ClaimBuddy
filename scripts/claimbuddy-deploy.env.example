APP_DIR=/root/Projects/ClaimBuddy
BRANCH=claimbuddy-split
SERVICE=claimbuddy-webapp
HOST=127.0.0.1
PORT=3020
ENV_FILE=/root/Projects/ClaimBuddy/.env.local
LOG=/var/log/claimbuddy-deploy.log
HEALTHCHECK_URL=http://127.0.0.1:3020/api/health

# Optional direct PostgreSQL URL for running supabase/claimbuddy.bootstrap.sql
# Leave empty to skip DB bootstrap during deploy.
CLAIMBUDDY_DB_URL=
RUN_DB_BOOTSTRAP=1

# Override only if you know you need different behavior.
INSTALL_CMD=npm ci
BUILD_CMD=npm run build

# Optional post-deploy smoke test.
RUN_SMOKE_TEST=0
SMOKE_TEST_CMD=/root/Projects/ClaimBuddy/scripts/claimbuddy-smoke.sh
TEST_USERNAME=
TEST_PASSWORD=
TEST_COMPANY_ID=
RUN_UPLOAD_DELETE_CHECK=0
