# ClaimBuddy - Environment Variables Template
# Copy this file to .env.local and fill in your values

# ============================================
# NEXT.JS
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================
# FIREBASE
# ============================================
# Get these from Firebase Console > Project Settings > General
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase Admin SDK (server-side only - KEEP SECRET!)
# Get from Firebase Console > Project Settings > Service Accounts
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ============================================
# GOOGLE AI (GEMINI)
# ============================================
# Get from https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your_gemini_api_key
GOOGLE_AI_MODEL=gemini-2.0-flash
GOOGLE_AI_MAX_TOKENS=2048
GOOGLE_AI_TEMPERATURE=0.7

# ============================================
# STRIPE (PAYMENTS)
# ============================================
# Get from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_PRICE_ID_SUCCESS_FEE=price_xxxxxxxxxxxxxxxxxxxxx

# ============================================
# GOPAY (CZ PAYMENTS)
# ============================================
# Get from https://help.gopay.com/
GOPAY_GO_ID=your_gopay_id
GOPAY_CLIENT_ID=your_gopay_client_id
GOPAY_CLIENT_SECRET=your_gopay_client_secret
GOPAY_IS_PRODUCTION=false

# ============================================
# EMAIL (RESEND)
# ============================================
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@claimbuddy.com
RESEND_FROM_NAME=ClaimBuddy

# Alternative: SendGrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@claimbuddy.com

# ============================================
# ANALYTICS
# ============================================
# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Vercel Analytics (auto-enabled on Vercel)
# No config needed

# ============================================
# ERROR TRACKING (SENTRY)
# ============================================
# Get from https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxx@xxxxx.ingest.sentry.io/xxxxx
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=claimbuddy

# ============================================
# RATE LIMITING
# ============================================
# Upstash Redis (for rate limiting in production)
# Get from https://upstash.com/
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxx

# Alternative: Use in-memory rate limiting (development only)
USE_MEMORY_RATE_LIMIT=true

# ============================================
# ENCRYPTION
# ============================================
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_32_character_encryption_key_here

# ============================================
# FILE UPLOAD LIMITS
# ============================================
MAX_FILE_SIZE_MB=25
MAX_FILES_PER_CASE=20
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png,image/heic,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ============================================
# BUSINESS SETTINGS
# ============================================
COMPANY_NAME=ClaimBuddy
COMPANY_EMAIL=info@claimbuddy.com
COMPANY_PHONE=+420123456789
SUPPORT_EMAIL=podpora@claimbuddy.com

# Success Fee (percentage)
SUCCESS_FEE_PERCENTAGE=15
MIN_FEE_CZK=5000
MAX_FEE_CZK=50000

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_AI_CHAT_ENABLED=true
FEATURE_OCR_ENABLED=true
FEATURE_STRIPE_ENABLED=true
FEATURE_GOPAY_ENABLED=true
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_SMS_NOTIFICATIONS=false

# ============================================
# DEVELOPMENT
# ============================================
# Enable debug logging
DEBUG=false

# Disable auth in development (NOT for production!)
DISABLE_AUTH_IN_DEV=false

# Seed database with test data
SEED_DATABASE=false

# ============================================
# PRODUCTION ONLY
# ============================================
# Vercel deployment
# VERCEL=1
# VERCEL_URL=claimbuddy.vercel.app
# VERCEL_ENV=production

# Database backup
# BACKUP_ENABLED=true
# BACKUP_BUCKET=claimbuddy-backups

# ============================================
# NOTES
# ============================================
# - NEVER commit .env.local to Git!
# - Add .env.local to .gitignore
# - Use Vercel Environment Variables for production
# - Rotate secrets regularly (API keys, tokens)
# - Use different keys for development/production
