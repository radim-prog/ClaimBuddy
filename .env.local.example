# =============================================================================
# ClaimBuddy — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Variables marked [REQUIRED] will crash the app or break core functionality.
# Variables marked [OPTIONAL] enable specific features — app works without them.

# -----------------------------------------------------------------------------
# Auth / Security [REQUIRED]
# -----------------------------------------------------------------------------

# HMAC secret for JWT signing. App throws Error on startup without this!
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Secret for /api/setup/first-admin endpoint (initial admin creation)
# Generate with: openssl rand -hex 16
SETUP_SECRET=

# Secret for authenticating cron job requests (Bearer token)
# Generate with: openssl rand -hex 16
CRON_SECRET=

# -----------------------------------------------------------------------------
# Supabase — ClaimBuddy DEDICATED claims database [REQUIRED]
# -----------------------------------------------------------------------------
# NEVER point this to UctoApp Supabase. ClaimBuddy běží na vlastní claims
# Supabase instanci (lokální docker compose: http://127.0.0.1:55421).
# Pokud tyto envy nejsou set v claims-only production buildu, server boot
# fail-fast (lib/database-config.ts → shouldDisallowFallback).
NEXT_PUBLIC_CLAIMS_SUPABASE_URL=
NEXT_PUBLIC_CLAIMS_SUPABASE_ANON_KEY=
CLAIMS_SUPABASE_SERVICE_ROLE_KEY=

# Legacy fallback envs — DRŽ PRÁZDNÉ v claims production deploy.
# Existují jen pro split-mode local dev, kde stejný kód umí běžet i v UctoApp
# instanci. V claims runtime tyto MUSÍ zůstat prázdné, jinak claims kód může
# číst UctoApp DB (data leak risk).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Safety switch — v produkci ClaimBuddy NIKDY nesmí fallbackovat na UctoApp DB.
# Drž 'false' na serveru. 'true' jen pro temporary local migration work.
ALLOW_ACCOUNTING_DB_FALLBACK=false

# -----------------------------------------------------------------------------
# Stripe — Payments & Subscriptions [OPTIONAL — requires MONETIZATION_ENABLED]
# -----------------------------------------------------------------------------

# Master kill switch: set to "true" to enable paid tiers, "false" = all features unlocked
MONETIZATION_ENABLED=false

# Stripe API keys (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Accountant tier Price IDs (from Stripe Dashboard → Products)
STRIPE_PRICE_PROFI_MONTHLY=price_...
STRIPE_PRICE_PROFI_YEARLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...

# Client tier Price IDs
STRIPE_PRICE_CLIENT_PLUS_MONTHLY=price_...
STRIPE_PRICE_CLIENT_PLUS_YEARLY=price_...
STRIPE_PRICE_CLIENT_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_CLIENT_PREMIUM_YEARLY=price_...

# Per-use addon Price IDs
STRIPE_PRICE_EXTRACTION_SINGLE=price_...
STRIPE_PRICE_EXTRACTION_BULK=price_...
STRIPE_PRICE_EXTRACTION_OPUS=price_...
STRIPE_PRICE_EXTRA_USER=price_...
STRIPE_PRICE_EXTRA_COMPANY=price_...
STRIPE_PRICE_RANDOMIZER=price_...

# Credit pack Price IDs (one-time purchase, used in /api/subscription/credits)
STRIPE_PRICE_CREDITS_50=price_...
STRIPE_PRICE_CREDITS_200=price_...

# -----------------------------------------------------------------------------
# AI / OCR Extraction [OPTIONAL — needed for document extraction]
# -----------------------------------------------------------------------------

# Primary AI provider: "openai" | "anthropic" | "gemini" | "zai"
AI_EXTRACTION_PROVIDER=openai
AI_EXTRACTION_MODEL=gpt-4o-mini

# OpenAI (extraction + voice transcription + summarization)
OPENAI_API_KEY=sk-...

# Anthropic Claude (alternative extraction provider)
ANTHROPIC_API_KEY=sk-ant-...

# Google Cloud API (used by AI extractor)
GOOGLE_CLOUD_API_KEY=your-google-cloud-api-key

# Kimi / Moonshot AI (bank statement OCR)
MOONSHOT_API_KEY=your-moonshot-api-key

# Z.AI (alternative OCR provider)
ZAI_API_KEY=your-zai-api-key

# -----------------------------------------------------------------------------
# Google Drive Integration [OPTIONAL]
# -----------------------------------------------------------------------------
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-drive-root-folder-id

# Google OAuth (for Drive file browser + Gmail integration)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REFRESH_TOKEN=your-refresh-token

# -----------------------------------------------------------------------------
# Notion Integration [OPTIONAL — for task sync bridge]
# -----------------------------------------------------------------------------
NOTION_TOKEN=ntn_...
# Data source ID for Notion tasks database (has hardcoded fallback)
NOTION_TASKS_DS_ID=your-notion-data-source-id

# -----------------------------------------------------------------------------
# Raynet CRM [OPTIONAL — for CRM sync]
# -----------------------------------------------------------------------------
RAYNET_API_KEY=your-raynet-api-key
RAYNET_EMAIL=your-raynet-email@example.com
RAYNET_INSTANCE_NAME=your-instance

# -----------------------------------------------------------------------------
# Twilio (SMS notifications) [OPTIONAL]
# -----------------------------------------------------------------------------
TWILIO_AUTH_TOKEN=your-auth-token

# -----------------------------------------------------------------------------
# Telegram Bot (notifications) [OPTIONAL]
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-bot-token

# -----------------------------------------------------------------------------
# Email Service [OPTIONAL — fallback chain: Ecomail → SendGrid → log-only]
# -----------------------------------------------------------------------------
EMAIL_FROM_NOREPLY=noreply@ucetnios.cz
ADMIN_EMAIL=admin@yourdomain.com

# -----------------------------------------------------------------------------
# Ecomail (Email marketing & transactional emails) [OPTIONAL]
# -----------------------------------------------------------------------------
# API key from Ecomail account → Spravovat ucet → Pro vyvojare
ECOMAIL_API_KEY=your-ecomail-api-key
ECOMAIL_LIST_ID_ACCOUNTANTS=your-list-id
ECOMAIL_LIST_ID_CLIENTS=your-list-id
# Automation IDs for triggered sequences
ECOMAIL_AUTOMATION_ONBOARDING=
ECOMAIL_AUTOMATION_TRIAL=
ECOMAIL_AUTOMATION_UPSELL=
ECOMAIL_AUTOMATION_WINBACK=

# -----------------------------------------------------------------------------
# SendGrid (Email notifications) [OPTIONAL — fallback if Ecomail unavailable]
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# WhatsApp via Evolution API [OPTIONAL]
# -----------------------------------------------------------------------------
EVOLUTION_API_URL=https://evolution.zajcon.cz
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=ucetni-webapp

# -----------------------------------------------------------------------------
# Signi (Document signing) [OPTIONAL]
# -----------------------------------------------------------------------------
SIGNI_API_KEY=your-signi-api-key
SIGNI_API_URL=https://api.signi.com

# -----------------------------------------------------------------------------
# Document Inbox [OPTIONAL — email-to-documents pipeline]
# -----------------------------------------------------------------------------
DOCUMENT_INBOX_EMAIL=doklady@yourdomain.com

# -----------------------------------------------------------------------------
# App Config [OPTIONAL — set the ClaimBuddy domain in standalone deploy]
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://claims.yourdomain.com

# -----------------------------------------------------------------------------
# Stripe Travel Add-on Price IDs [OPTIONAL — Travel AI Randomizer]
# -----------------------------------------------------------------------------
STRIPE_PRICE_TRAVEL_REGEN=price_...
STRIPE_PRICE_TRAVEL_YEARLY_SINGLE=price_...
STRIPE_PRICE_TRAVEL_YEARLY_FLEET=price_...
