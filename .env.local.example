# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini (OCR)
GEMINI_API_KEY=your-gemini-api-key

# OpenAI (AI Chat)
OPENAI_API_KEY=your-openai-api-key

# Pohoda mServer
POHODA_MSERVER_URL=https://your-pohoda-server.com/xml
POHODA_USERNAME=your-username
POHODA_PASSWORD=your-password

# Google Drive API
GOOGLE_DRIVE_CLIENT_ID=your-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-client-secret
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/google-auth/callback
GOOGLE_DRIVE_REFRESH_TOKEN=your-refresh-token

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+420123456789

# SendGrid (Email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=ucetnictvi@your-domain.cz

# WhatsApp Business API
WHATSAPP_BUSINESS_ID=your-business-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-verify-token

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
