# Notion backend (required)
NOTION_TOKEN=secret_xxx
NOTION_CASES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional admin protection for internal API actions
ADMIN_API_KEY=change_me
ADMIN_PANEL_PASSWORD=change_me
ADMIN_SESSION_TOKEN=change_me_random_token

# AI (optional)
GOOGLE_AI_API_KEY=your_gemini_api_key

# Email notifications (optional)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=noreply@your-domain.cz

# Payments (optional)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000
