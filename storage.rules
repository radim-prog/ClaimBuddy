rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper funkce
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAccountant() {
      return isAuthenticated() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['accountant', 'admin'];
    }

    // Companies storage: /companies/{companyId}/...
    match /companies/{companyId}/{allPaths=**} {
      // Číst můžou klienti (své) a accountanti (všechny)
      allow read: if isAuthenticated() && (
        firestore.get(/databases/(default)/documents/companies/$(companyId)).data.owner_id == request.auth.uid ||
        isAccountant()
      );

      // Nahrávat můžou klienti (své) a accountanti (všechny)
      allow write: if isAuthenticated() && (
        firestore.get(/databases/(default)/documents/companies/$(companyId)).data.owner_id == request.auth.uid ||
        isAccountant()
      );
    }

    // Ostatní storage (jen accountant)
    match /{allPaths=**} {
      allow read, write: if isAccountant();
    }
  }
}
